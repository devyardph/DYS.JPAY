@using DYS.JPay.Shared.Shared.Entities
<div class="flex items-center justify-between p-6 border-b border-outline-variant/10 bg-surface-container-low/30">
    <div>
        <h2 id="offcanvas-title" class="text-2xl font-headline font-extrabold text-primary">
            @Product.Name variants
        </h2>
        <p id="offcanvas-subtitle" class="text-sm font-bold text-primary mt-1">
            Price: @Currency@Product.Price?.ToString("N2")
        </p>
    </div>
    <button @onclick="@AddMoreVariant"
            class="p-2 hover:bg-surface-container-highest rounded-full transition-colors text-on-surface-variant">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 5v14M5 12h14"></path>
        </svg>
    </button>

</div>

<div class="flex-1 overflow-y-auto p-6 no-scrollbar">
    <form id="canvass-form" onsubmit="event.preventDefault(); closeOffcanvas();" class="space-y-3">
        @if (Variants.Any())
        {
            <div class="flex space-x-4">
                <!-- Product Name -->
                <div class="flex-1">
                    <label class="text-xs text-on-surface-variant uppercase tracking-wider pl-1">Product variants</label>
                             </div>

              
            

            </div>
            @foreach (var variant in Variants)
            {
                <div class="flex space-x-4">
                    <!-- Product Name -->
                    <div class="flex-1">
                      
                        <input id="product-name"
                               @bind-value="@variant.Name"
                        type="text"
                        
                        placeholder="e.g. S,M or XL"
                        class="w-full px-5 py-4 bg-surface-container-low border-none rounded-2xl text-sm focus:ring-2 focus:ring-primary transition-all outline-none" />
                    </div>

                    <!-- Price -->
                    <div class="w-40">
                      
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 font-bold text-primary">@Currency</span>
                            <input @bind-value="@variant.Price"
                            type="number"
                            step="0.01"
                            required
                            placeholder="0.00"
                            class="w-full pl-10 pr-5 py-4 bg-surface-container-low border-none rounded-2xl text-sm focus:ring-2 focus:ring-primary transition-all outline-none" />
                        </div>
                    </div>
                    <!-- Remove Button -->
                    <button @onclick="@(() => RemoveVariant(variant))" class="text-error/70 hover:text-error p-1">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="24" height="24" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round"
                             class="lucide lucide-x w-4 h-4" aria-hidden="true">
                            <path d="M18 6 6 18"></path>
                            <path d="m6 6 12 12"></path>
                        </svg>
                    </button>
                </div>
            }
        }
    </form>
</div>

<div class="p-6 border-t border-outline-variant/10 bg-surface-container-lowest flex gap-3 mb-5">
    <button onclick="closeOffcanvas('variant-overlay','variant-component')" class="flex-1 py-2 bg-surface-container-highest text-on-surface rounded-2xl font-bold hover:bg-outline-variant/30 transition-colors">
        Cancel
    </button>
    <button @onclick="@OnSave" id="offcanvas-submit" type="submit" form="user-form" class="flex-1 py-2 bg-primary text-white rounded-2xl font-bold shadow-xl active:scale-95 transition-all">
        Save variants
    </button>
</div>

@code {
    [Parameter]
    public string Currency { get; set; } = string.Empty;
    [Parameter]
    public string ActionText { get; set; } = string.Empty;
    [Parameter]
    public bool IsBusy { get; set; }
    [Parameter]
    public ProductDto Product { get; set; } = new ProductDto();
    [Parameter]
    public List<VariantDto> Variants { get; set; } = new List<VariantDto>();
    [Parameter]
    public EventCallback<List<VariantDto>> VariantsChanged { get; set; }
    [Parameter]
    public EventCallback Save { get; set; }

    public void OnSave()
    {
        VariantsChanged.InvokeAsync(Variants);
        Save.InvokeAsync();
    }

    public void InitializeContents(ProductDto product, List<VariantDto> variants)
    {

        if (!variants.Any())
        {
            var variant = new VariantDto();
            variant.Id = Guid.NewGuid();
            variant.ProductId = Product.Id;
            variant.Name = "";
            variant.Price = 0;
            variants.Add(variant);
        }
        Product = product;
        Variants = variants;
        StateHasChanged();

    }

    public void AddMoreVariant()
    {
        var variant = new VariantDto();
        variant.Id = Guid.NewGuid();
        variant.ProductId = Product.Id;
        variant.Name = "";
        variant.Price = 0;
        Variants.Add(variant);
        StateHasChanged();
    }

    public void RemoveVariant(VariantDto variant)
    {
        if (Variants.Count > 1)
        {
            Variants.RemoveAll(query => query.Id == variant.Id);
            StateHasChanged();
        }
    }
}
