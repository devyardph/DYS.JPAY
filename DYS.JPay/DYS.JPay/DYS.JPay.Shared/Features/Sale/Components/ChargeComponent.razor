@inject IJSRuntime JS

<div id="charge-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4 hidden opacity-0 transition-opacity duration-300 ease-in-out">
    <div class="bg-surface-container-lowest rounded-3xl p-8 max-w-lg w-full shadow-2xl transform scale-95 transition-transform duration-300" id="charge-modal-content">
        <!-- Payment Info -->
        <div class="mb-6">
            <div class="flex items-center justify-center relative mb-1">
                <!-- Left button -->
                <div class="absolute left-0">
                    <button @onclick="@BackToPayment" class="p-2 hover:bg-surface-container-highest rounded-full transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="24" height="24" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round"
                             class="lucide lucide-arrow-right w-5 h-5 rotate-180"
                             aria-hidden="true">
                            <path d="M5 12h14"></path>
                            <path d="m12 5 7 7-7 7"></path>
                        </svg>
                    </button>
                </div>

                <!-- Centered amount -->
                <div class="text-center mb-3 p-2 rounded-xl">
                    <h2 class="text-5xl font-headline font-bold text-primary mb-2">
                        @Order?.Total?.ToString("c2")
                    </h2>
                    <label class="text-[10px] font-bold uppercase tracking-widest text-[#40484c]">
                        amount due
                    </label>
                </div>

                <!-- Right placeholder (optional) -->
                <div class="absolute right-0">
                    <button @onclick="@ClosePayment" class="p-2 hover:bg-surface-container-highest rounded-full transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="24" height="24" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round"
                             class="lucide lucide-x w-5 h-5"
                             aria-hidden="true">
                            <path d="M18 6L6 18"></path>
                            <path d="M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

           

            <div class="space-y-2">
                <div class="flex justify-between gap-3">
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-[#40484c]">Amount tender</label>
                        <div class="relative">
                            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-bold text-[#003345]">$</span>
                            <input type="number" placeholder="0.00" class="w-full bg-[#f1f4fa] border-none rounded-2xl pl-10 pr-6 py-4 text-base font-headline font-bold focus:ring-2 focus:ring-[#003345] transition-all">
                        </div>
                    </div>
                    <div class="space-y-2 text-right">
                        <label class="text-[10px] font-bold  uppercase tracking-widest text-[#40484c]">Change</label>
                        <div class="relative">
                            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-bold text-[#003345]">$</span>
                            <input disabled type="number" placeholder="0.00" class="w-full bg-[#f1f4fa] border-none rounded-2xl pl-10 pr-6 py-4 text-base font-headline font-bold focus:ring-2 focus:ring-[#003345] transition-all">
                        </div>
                    </div>
                </div>
               
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-[#40484c]">Customer Name</label>
                    <input type="text" placeholder="eg. Name" class="w-full bg-[#f1f4fa] border-none rounded-2xl px-6 py-4 text-base font-headline font-bold focus:ring-2 focus:ring-[#003345] transition-all">
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase tracking-widest text-[#40484c]">Reference no.</label>
                    <input type="text" placeholder="e.g. 23423" class="w-full bg-[#f1f4fa] border-none rounded-2xl px-6 py-4 text-base font-headline font-bold focus:ring-2 focus:ring-[#003345] transition-all">
                </div>
            </div>
        </div>

        <!-- Confirm Button -->
        <div class="flex items-center gap-3 mb-0">
            <button @onclick="@(() => OnPlaceOrder())" class="w-full text-uppercase ledger-gradient text-white py-4 rounded-xl  shadow-lg active:scale-95 transition-all flex items-center justify-center gap-2">
               CONFIRM PAYMENT
            </button>
        </div>
      
    </div>
</div>

@code {
    [Parameter]
    public OrderDto Order { get; set; } = new OrderDto();
    [Parameter]
    public EventCallback<OrderDto> OrderChanged { get; set; }
    [Parameter]
    public EventCallback PlaceOrder { get; set; }

    public async Task OnPlaceOrder() => await PlaceOrder.InvokeAsync();

    public async Task BackToPayment()
    {
        await JS.InvokeVoidAsync("closeModal", "charge-modal");
        await JS.InvokeVoidAsync("openModal", "payment-modal");
    }

    public async Task ClosePayment()
    {
        await JS.InvokeVoidAsync("closeModal", "charge-modal");
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) StateHasChanged();
        return base.OnAfterRenderAsync(firstRender);
    }

}
