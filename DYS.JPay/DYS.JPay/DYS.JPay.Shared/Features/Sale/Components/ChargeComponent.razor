@inject IJSRuntime JS

<div id="charge-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4 hidden opacity-0 transition-opacity duration-300 ease-in-out">
    <div class="bg-surface-container-lowest rounded-3xl p-8 max-w-md w-full shadow-2xl transform scale-95 transition-transform duration-300" id="charge-modal-content">
        <!-- Header -->
        <div class="flex items-center gap-3 mb-6">
            <button @onclick="BackToPayment" class="p-2 hover:bg-surface-container-highest rounded-full transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg"
                     width="24" height="24" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round"
                     class="lucide lucide-arrow-right w-5 h-5 rotate-180"
                     aria-hidden="true">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                </svg>
            </button>
            <h2 class="text-2xl font-headline font-bold text-primary">Enter Reference</h2>
        </div>

        <!-- Payment Info -->
        <div class="mb-6">
           
            <div class="flex items-center justify-between mb-4 p-4 bg-surface-container-low rounded-xl">
                <span class="text-on-surface-variant">
                    Method: <strong class="text-on-surface">@Order.PaymentMode</strong>
                </span>
                <span class="text-on-surface-variant">
                    Amount: <strong class="text-primary">$@Order?.Total</strong>
                </span>
            </div>

            <!-- Reference Input -->
            <div>
                <label class="block text-sm font-bold text-on-surface-variant mb-2">
                    Customer name
                </label>
                <input type="text" @bind-value="@Order.CustomerName"
                       placeholder="e.g. Receipt #, Auth Code"
                       class="w-full bg-surface-container-low border border-outline-variant/30 rounded-xl px-4 py-3 text-on-surface
                focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
            </div>
            <div>
                <label class="block text-sm font-bold text-on-surface-variant mb-2">
                    Reference Code (Optional)
                </label>
                <input type="text" @bind-value="@Order.ReferenceNo"
                       placeholder="e.g. Receipt #, Auth Code"
                       class="w-full bg-surface-container-low border border-outline-variant/30 rounded-xl px-4 py-3 text-on-surface
                focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all" />
            </div>
        </div>

        <!-- Confirm Button -->
        <button @onclick="@(() => OnPlaceOrder())" class="w-full ledger-gradient text-white py-4 rounded-xl font-bold shadow-lg active:scale-95 transition-all flex items-center justify-center gap-2">
            Confirm Payment
        </button>
    </div>
</div>

@code {
    [Parameter]
    public OrderDto Order { get; set; } = new OrderDto();
    [Parameter]
    public EventCallback<OrderDto> OrderChanged { get; set; }
    [Parameter]
    public EventCallback PlaceOrder { get; set; }

    public async Task OnPlaceOrder() => await PlaceOrder.InvokeAsync();

    public async Task BackToPayment()
    {
        await JS.InvokeVoidAsync("closeModal", "charge-modal");
        await JS.InvokeVoidAsync("openModal", "payment-modal");
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) StateHasChanged();
        return base.OnAfterRenderAsync(firstRender);
    }

}
