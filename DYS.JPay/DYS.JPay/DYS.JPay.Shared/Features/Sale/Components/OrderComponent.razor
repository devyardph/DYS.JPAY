@using DYS.JPay.Shared.Shared.Dtos
<div class="flex items-center justify-between gap-0 p-2 rounded-xl transition-all duration-500" id="cart-@Id">
    <!-- Item Info -->
    <div class="flex-1">
        <h4 class="font-bold text-sm text-on-surface">@OrderItem.Product.Name</h4>
        <p class="text-xs text-on-surface-variant">$@OrderItem.Product.Price</p>
    </div>
    <!-- Quantity Controls -->
    <div class="flex items-center gap-3 bg-surface-container-low rounded-lg p-1">
        <button @onclick="@DecreaseOrder" class="w-6 h-6 flex items-center justify-center rounded-md hover:bg-white text-on-surface-variant hover:text-primary transition-colors">-</button>
        <span class="text-sm font-bold w-4 text-center">@OrderItem.Count</span>
        <button @onclick="@IncreaseOrder" class="w-6 h-6 flex items-center justify-center rounded-md hover:bg-white text-on-surface-variant hover:text-primary transition-colors">+</button>
    </div>
    <!-- Price -->
    <div class="text-right w-16">
        <p class="font-bold text-sm">$@((OrderItem.Product.Price * @OrderItem.Count)?.ToString("N2"))</p>
    </div>
    <!-- Remove Button -->
    <button class="text-error/70 hover:text-error p-1" @onclick="@(() => OnRemoveOrder(OrderItem))">
        <svg xmlns="http://www.w3.org/2000/svg"
             width="24" height="24" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round"
             class="lucide lucide-x w-4 h-4" aria-hidden="true">
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
        </svg>
    </button>
</div>

@code {
    [Parameter]
    public string Id { get; set; }
    [Parameter]
    public OrderItemDto OrderItem { get; set; } = new OrderItemDto();
    [Parameter]
    public EventCallback<OrderItemDto> RemoveOrder { get; set; }

    public void OnRemoveOrder(OrderItemDto order)
    {
        RemoveOrder.InvokeAsync(order);
    }

    public void IncreaseOrder()
    {
        OrderItem.Count = OrderItem.Count + 1;
    }

    public void DecreaseOrder()
    {
        OrderItem.Count = OrderItem.Count - 1;
        if (OrderItem.Count == 0)
            RemoveOrder.InvokeAsync(OrderItem);
    }
}
