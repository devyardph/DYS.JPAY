@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<div id="result-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4 hidden opacity-0 transition-opacity duration-300">
    <div class="bg-surface-container-lowest rounded-3xl p-8 max-w-sm w-full shadow-2xl text-center transform scale-95 transition-transform duration-300" id="result-modal-content">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h2 class="text-2xl font-headline font-bold text-on-surface mb-2">Payment Successful</h2>
        <p class="text-on-surface-variant mb-8">Order has been completed and receipt generated.</p>
       @*  <button @onclick="@Complete" class="w-full ledger-gradient text-white py-3 rounded-xl font-bold shadow-lg hover:shadow-xl transition-all">
            New Order
        </button> *@
        <!-- Progress bar -->
        <div class="w-full bg-gray-200 rounded-full h-2 mt-4 overflow-hidden">
            <div id="progress-bar" class="bg-green-600 h-2 w-full"></div>
        </div>


    </div>
</div>

@code {

    [Parameter]
    public OrderDto Order { get; set; } = new OrderDto();
    [Parameter]
    public List<OrderItemDto> OrderItems { get; set; } = new List<OrderItemDto>();
    [Parameter]
    public EventCallback<OrderDto> OrderChanged { get; set; }
    [Parameter]
    public EventCallback<List<OrderItemDto>> OrderItemsChanged { get; set; }

    public async Task Complete()
    {
        await JS.InvokeVoidAsync("closeModal", "result-modal");
        await OrderChanged.InvokeAsync(new OrderDto());
        await OrderItemsChanged.InvokeAsync(new List<OrderItemDto>());
    }
}
