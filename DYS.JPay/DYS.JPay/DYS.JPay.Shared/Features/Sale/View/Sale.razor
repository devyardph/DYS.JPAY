@page "/"
@using DYS.JPay.Shared.Features.Products.ViewModels
@using DYS.JPay.Shared.Features.Sale.Components
@inject IJSRuntime JS
@inject SaleViewModel VM


<div id="main-content" class="flex-1 lg:ml-64 h-full overflow-hidden flex flex-col lg:flex-row transition-all duration-300">
    <main class="flex-1 p-4 md:p-8 lg:pr-[26rem] opacity-0 animate-fade-in-up overflow-y-auto no-scrollbar">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-headline font-bold text-primary">@VM.AppSetting.StoreName</h1>
                <p class="text-on-surface-variant">@VM.AppSetting.StoreDescription</p>
            </div>
            <div class="flex items-center gap-2 w-full sm:w-auto">
                <div class="relative flex-1 sm:w-64">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <input type="text" placeholder="Search products..." class="w-full pl-10 pr-4 py-2 bg-surface-container-lowest border border-outline-variant/20 rounded-xl text-sm focus:ring-1 focus:ring-primary transition-all" />
                </div>

                <div class="flex items-center bg-surface-container-low rounded-lg p-1 shrink-0">
                    <!-- Grid View Button -->
                    <button @onclick="@(() => @VM.SetDisplay("grid"))" class="p-2 rounded-md transition-colors shadow-sm @BooleanExtensions.GetConditionalString(VM.AppSetting.Display == "grid", "bg-white text-primary", "text-on-surface-variant hover:text-primary")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="24" height="24"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             class="lucide lucide-layout-grid w-5 h-5"
                             aria-hidden="true">
                            <rect width="7" height="7" x="3" y="3" rx="1"></rect>
                            <rect width="7" height="7" x="14" y="3" rx="1"></rect>
                            <rect width="7" height="7" x="14" y="14" rx="1"></rect>
                            <rect width="7" height="7" x="3" y="14" rx="1"></rect>
                        </svg>
                    </button>

                    <!-- List View Button -->
                    <button @onclick="@(() => @VM.SetDisplay("list"))" class="p-2 rounded-md transition-colors @BooleanExtensions.GetConditionalString(VM.AppSetting.Display == "list", "bg-white text-primary", "text-on-surface-variant hover:text-primary")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="24" height="24"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             class="lucide lucide-list w-5 h-5"
                             aria-hidden="true">
                            <path d="M3 5h.01"></path>
                            <path d="M3 12h.01"></path>
                            <path d="M3 19h.01"></path>
                            <path d="M8 5h13"></path>
                            <path d="M8 12h13"></path>
                            <path d="M8 19h13"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div class="flex gap-2 overflow-x-auto no-scrollbar pb-4 mb-4">
            <button @onclick="@(() => VM.FilterProducstsAsync(""))" class="px-4 py-2 rounded-xl text-sm font-bold whitespace-nowrap transition-all bg-primary text-white shadow-md">All Items</button>
            <button @onclick="@(() => VM.FilterProducstsAsync("Coffee"))" class="px-4 py-2 rounded-xl text-sm font-bold whitespace-nowrap transition-all bg-surface-container-lowest text-on-surface-variant hover:bg-surface-container-highest border border-outline-variant/10">Coffee</button>
            <button @onclick="@(() => VM.FilterProducstsAsync("Pastries"))" class="px-4 py-2 rounded-xl text-sm font-bold whitespace-nowrap transition-all bg-surface-container-lowest text-on-surface-variant hover:bg-surface-container-highest border border-outline-variant/10">Pastries</button>
            <button @onclick="@(() => VM.FilterProducstsAsync("Tea"))" class="px-4 py-2 rounded-xl text-sm font-bold whitespace-nowrap transition-all bg-surface-container-lowest text-on-surface-variant hover:bg-surface-container-highest border border-outline-variant/10">Merch</button>
        </div>

        <!-- Products Grid -->
        <ProductsComponent Display="@VM.AppSetting.Display" Products="@VM.FilteredProducts" AddToOrder="VM.AddOrder" />
        <!-- Products Grid -->

    </main>
    <div class="pb-5 w-full lg:fixed lg:right-0 lg:top-0 h-full lg:w-96 bg-surface-container-lowest lg:rounded-none rounded-3xl border border-outline-variant/10 lg:border-y-0 lg:border-r-0 lg:border-l flex flex-col overflow-hidden shadow-sm lg:shadow-2xl z-40 overflow-y-auto no-scrollbar">
        <div class="p-6 border-b border-outline-variant/10 bg-surface-container-low/50">
            <h2 class="text-xl font-headline font-bold text-primary flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                Sale Today
            </h2>
        </div>
      
        <CartComponent OrderItems="@VM.OrderItems" OrderChanged="@VM.OrderChanged" />
      
        <div class="p-6 border-t border-outline-variant/10 bg-surface-container-low/30">
            <div class="space-y-2 mb-4">
                <div class="flex justify-between text-sm text-on-surface-variant">
                    <span>Subtotal</span>
                    <span id="cart-subtotal">$@VM.Order.Total?.ToString("N2")</span>
                </div>
                <div class="flex justify-between text-sm text-on-surface-variant">
                    <span>Tax (8%)</span>
                    <span id="cart-tax">$0.00</span>
                </div>
                <div class="flex justify-between text-lg font-black text-primary pt-2 border-t border-outline-variant/10">
                    <span>Total</span>
                    <span id="cart-total">$@VM.Order.Total?.ToString("N2")</span>
                </div>
            </div>
            <button id="charge-btn" @onclick="@ProcessOrder" class="w-full ledger-gradient text-white py-5 rounded-xl font-bold shadow-lg active:scale-95 transition-all text-lg flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed active:scale-95">
                Charge <span id="charge-amount">$@VM.Order.Total?.ToString("N2")</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
            <p></p>
        </div>
    </div>
</div>

<PaymentComponent @bind-Order="@VM.Order"/>
<ChargeComponent @bind-Order="@VM.Order" PlaceOrder="@VM.ChargeAsync"/>
<ResultComponent @bind-Order="@VM.Order" @bind-OrderItems="@VM.OrderItems" />

@code {
    @code {
        protected override async Task OnInitializedAsync()
        {
            await VM.LoadAppSetting();
            await VM.GetProductsAsync();
            await base.OnInitializedAsync();
            StateHasChanged();
        }

        protected override async Task OnAfterRenderAsync(bool firstRender)
        {
            if (!string.IsNullOrEmpty(VM.PendingCartId))
            {
                await JS.InvokeVoidAsync("animateCart", VM.PendingCartId);
                VM.PendingCartId = string.Empty;
            }
        }

        public async Task ProcessOrder()
        {
            await JS.InvokeVoidAsync("openModal", "payment-modal");
        }
    }

}
