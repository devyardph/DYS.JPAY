@page "/login"
@layout EmptyLayout
@using DYS.JPay.Shared.Features.Accounts.ViewModels
@using DYS.JPay.Shared.Shared.Services
@using Microsoft.AspNetCore.Authorization
@inject LoginViewModel LoginVM

<div class="h-full flex items-center justify-center p-4 bg-primary-subtle ">
    <div class="w-full max-w-md ">

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 animate-fade-in-up">
            <div class="text-center mb-8">
                <h1 class="text-5xl font-black font-headline text-primary tracking-tight">JPay</h1>
                <p class="text-sm text-gray-500 font-medium mt-1">Point of Sale System</p>
            </div>
        
            <form class="space-y-4">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-1">Username</label>
                    <input @bind-value="@LoginVM.Profile.Username" type="text" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="">
                </div>
                <div>
                    <div class="flex justify-between items-center mb-2">
                        <label class="block text-sm font-bold text-on-surface-variant">6-Digit Code</label>
                    </div>
                    <input type="password" @bind-value="@LoginVM.Profile.Passcode" required maxlength="6" pattern="\d{6}" placeholder="••••••" class="w-full bg-surface-container-low border border-outline-variant/30 rounded-xl px-4 py-3 text-on-surface focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all tracking-[0.5em] text-center" />
                </div>
                <button type="button" @onclick="@LoginVM.BasicLogin" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 rounded-xl transition-colors shadow-md mt-2">Sign In</button>
            </form>
            <p class="text-center text-sm text-gray-500 mt-6 font-medium">
                Don't have an account? <a href="register.html" class="text-secondary font-bold hover:underline">Register</a>
            </p>
        </div>
    
    </div>
</div>

@code{

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
    }

}

